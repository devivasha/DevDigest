# @devdigest/mcp-server environment
# Base URL of the DevDigest API (started via ./scripts/dev.sh). No secrets here.
DEVDIGEST_API_URL=http://localhost:3001

# How long run_agent_on_pr blocks inline (ms) before returning {status:'running',
# run_id}. Keep it under your MCP client's request timeout (commonly ~60s) to
# avoid "MCP error -32001: Request timed out". Default: 45000.
# DEVDIGEST_INLINE_WAIT_MS=45000
