{
  "name": "@devdigest/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local stdio MCP server exposing DevDigest review tools to Claude Code (thin HTTP client over the API on :3001).",
  "scripts": {
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
